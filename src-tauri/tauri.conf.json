    "targets": [
      "msi"
    ],
    "category": "Productivity",
    "shortDescription": "Personal AI operating system for chat, memory, files, and automation.",
    "longDescription": "ORION is a personal AI operating system with chat, memory, tasks, files, voice, automation, inbox capture, and self-learning.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US",
        "upgradeCode": "A9C1B5D4-3D6E-4E1E-8B49-1A0D8B7E64F2"
      }
    }
  },
  "plugins": {}
}
