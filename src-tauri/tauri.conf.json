{
  "productName": "ORION",
  "version": "0.1.0",
  "identifier": "com.pallasite99.orion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "http://localhost:3000"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "ORION",
        "width": 1280,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
